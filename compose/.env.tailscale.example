# Tailscale remote access — Podman rootless + tailnet hostnames
# Full walkthrough: docs/deploy-podman-tailscale.md

HARBOUR_ROOT=../..
HARBOUR_DEPLOY_PROFILE=tailscale

# Traefik config with Tailscale Let's Encrypt cert resolver (requires HTTPS certs in Tailscale admin).
HARBOUR_TRAEFIK_CONFIG=traefik.podman.tailscale.yml

# Replace tailabc123 with your tailnet name (Admin console → DNS → Tailnet name).
HARBOUR_DNS_ZONE=harbour.tailabc123.ts.net
HARBOUR_COOKIE_DOMAIN=.harbour.tailabc123.ts.net

# Stable 100.x address of the Harbour host (tailscale ip -4 on the server).
HARBOUR_TAILSCALE_IP=100.64.0.1

# Podman rootless (default for scripts/up.sh) — clients must use :8443 in URLs
HARBOUR_PUBLIC_HTTPS_PORT=8443
HOST_HTTP_PORT=8081
HOST_HTTPS_PORT=8443
HOST_TRAEFIK_DASHBOARD_PORT=9080

PORTCULLIS_ISSUER=https://harbour.tailabc123.ts.net:8443
VITE_OIDC_ISSUER=https://harbour.tailabc123.ts.net:8443
VITE_OIDC_CLIENT_ID=harbour-shell
VITE_HARBOUR_SHELL_URL=https://harbour.tailabc123.ts.net:8443
SESSION_COOKIE_DOMAIN=.harbour.tailabc123.ts.net

# Docker rootful alternative (no :8443 in URLs) — use scripts/docker/up.sh instead:
# HARBOUR_PUBLIC_HTTPS_PORT=443
# HOST_HTTP_PORT=80
# HOST_HTTPS_PORT=443
# HOST_TRAEFIK_DASHBOARD_PORT=8080
# PORTCULLIS_ISSUER=https://harbour.tailabc123.ts.net
# VITE_OIDC_ISSUER=https://harbour.tailabc123.ts.net
# VITE_HARBOUR_SHELL_URL=https://harbour.tailabc123.ts.net

SESSION_SECRET=change-me-in-production-min-16-chars
POSTGRES_USER=harbour
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=harbour
IDP_MODE=local

# Voice / WebRTC over tailnet
SFU_ANNOUNCED_IP=100.64.0.1
CHAT_VOICE_TURN_URLS=stun:harbour.tailabc123.ts.net:13478,turn:harbour.tailabc123.ts.net:13478?transport=udp
TURN_REALM=harbour.tailabc123.ts.net

CHAT_VOICE_SFU_BASE_URL=http://harbour-chat-sfu:4000
CHAT_VOICE_TURN_TTL_SECONDS=3600
CHAT_SFU_HTTP_PORT=14000
CHAT_SFU_RTP_UDP_START=14050
CHAT_SFU_RTP_UDP_END=14150
TURN_STATIC_AUTH_SECRET=harbour-dev-turn-secret
TURN_LISTEN_PORT=13478
TURN_RELAY_MIN_PORT=14200
TURN_RELAY_MAX_PORT=14300

HARBOUR_PROXY_TOKEN=harbour-dev-proxy-token
CHAT_MASTER_KEY_B64=QkJCQkJCQkJCQkJCQkJCQkJCQkJCQkJCQkJCQkJCQkI=
CHAT_MASTER_KEY_ID=chat-kek-v1
REQUIRE_HTTPS_FORWARDED_PROTO=true
