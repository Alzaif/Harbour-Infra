# Parent directory containing harbour-* service repos (Harbour workspace root)
HARBOUR_ROOT=../..

# Shared secret for Portcullis session cookies (min 16 characters)
SESSION_SECRET=change-me-in-production-min-16-chars

# Public DNS zone — shell hostname (Traefik Host rules derive app hosts as {app}.${HARBOUR_DNS_ZONE})
# Local dev: harbour.local | Tailscale remote: harbour.<your-tailnet>.ts.net
HARBOUR_DNS_ZONE=harbour.local

# Public URLs (must match Traefik Host rules and UI build args)
# Rootless Podman (scripts/up.sh): use https://harbour.local:8443
# Docker (scripts/docker/up.sh): use https://harbour.local
PORTCULLIS_ISSUER=https://harbour.local:8443
VITE_OIDC_ISSUER=https://harbour.local:8443
VITE_OIDC_CLIENT_ID=harbour-shell
VITE_HARBOUR_SHELL_URL=https://harbour.local:8443
SESSION_COOKIE_DOMAIN=.harbour.local

# HTTPS port clients use in browser (443 Docker; 8443 Podman rootless). Used by generate-public-config.sh.
HARBOUR_PUBLIC_HTTPS_PORT=8443

# Deploy profile: local (default) | tailscale — see docs/tailscale-remote-access.md
# HARBOUR_DEPLOY_PROFILE=local

# Tailscale host tailnet IP (required for remote voice/WebRTC when profile=tailscale)
# HARBOUR_TAILSCALE_IP=100.x.x.x

# Podman rootless — host ports mapped to Traefik (>= 1024; scripts/up.sh sets defaults)
HOST_HTTP_PORT=8081
HOST_HTTPS_PORT=8443
HOST_TRAEFIK_DASHBOARD_PORT=9080

# Podman only — Traefik API socket (auto-detected by scripts/up.sh if unset)
# Rootless (typical): /run/user/1000/podman/podman.sock
# Rootful: /run/podman/podman.sock
# PODMAN_SOCKET=/run/user/1000/podman/podman.sock

# PostgreSQL (Portcullis identity store)
POSTGRES_USER=harbour
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=harbour

# Optional overrides
# local = email/password sign-in + Postgres; stub = dev user picker (use docker-compose.stub.yml)
IDP_MODE=local
PORTCULLIS_VERSION=local
UI_VERSION=local
NOTES_VERSION=local
DOCS_VERSION=local
GYM_VERSION=local
RECIPES_VERSION=local
OUTLINE_VERSION=local
CHAT_VERSION=local
CHAT_SFU_VERSION=local
WAREHOUSE_VERSION=local
STACK_VERSION=local

# harbour-stack host disk stats (Docker overlay only; leave unset on rootless Podman)
# STACK_HOST_DISK_PATH=/host-docker

# Security defaults for local development (override in production)
HARBOUR_PROXY_TOKEN=harbour-dev-proxy-token
CHAT_MASTER_KEY_B64=QkJCQkJCQkJCQkJCQkJCQkJCQkJCQkJCQkJCQkJCQkI=
CHAT_MASTER_KEY_ID=chat-kek-v1
REQUIRE_HTTPS_FORWARDED_PROTO=true

# Harbour Notes — GitHub content monorepo (required; also copy to harbour-notes/.env.local for npm dev)
# NOTES_GITHUB_REPO=your-org/harbour-notes-content
# NOTES_GITHUB_TOKEN=ghp_...
# NOTES_GITHUB_BASE_BRANCH=main

# Phase 4 voice transport defaults (rootless-safe local ports)
CHAT_VOICE_SFU_BASE_URL=http://harbour-chat-sfu:4000
CHAT_VOICE_TURN_URLS=stun:turn.harbour.local:13478,turn:turn.harbour.local:13478?transport=udp
CHAT_VOICE_TURN_TTL_SECONDS=3600
CHAT_SFU_HTTP_PORT=14000
CHAT_SFU_RTP_UDP_START=14050
CHAT_SFU_RTP_UDP_END=14150
TURN_STATIC_AUTH_SECRET=harbour-dev-turn-secret
TURN_LISTEN_PORT=13478
TURN_RELAY_MIN_PORT=14200
TURN_RELAY_MAX_PORT=14300
SFU_ANNOUNCED_IP=127.0.0.1
TURN_REALM=harbour.local
